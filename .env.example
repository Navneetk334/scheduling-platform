# ============================================================================
# INVINCIBLE PROS — Scheduling Platform environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Core ---
NODE_ENV=development
APP_NAME="INVINCIBLE PROS"
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduling?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Better Auth ---
BETTER_AUTH_SECRET="replace-with-a-64-char-random-secret"
BETTER_AUTH_URL=http://localhost:4000

# --- S3-compatible storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=scheduling-assets
S3_FORCE_PATH_STYLE=true

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM="INVINCIBLE PROS <no-reply@example.com>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+10000000000

# --- Calendar / Video OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Observability ---
LOG_LEVEL=debug
