# ============================================================================
# INVINCIBLE PROS — Scheduling Platform environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Core ---
NODE_ENV=development
APP_NAME="INVINCIBLE PROS"
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduling?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Better Auth ---
BETTER_AUTH_SECRET="replace-with-a-64-char-random-secret"
BETTER_AUTH_URL=http://localhost:4000

# --- S3-compatible storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=scheduling-assets
S3_FORCE_PATH_STYLE=true

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM="INVINCIBLE PROS <no-reply@example.com>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+10000000000

# ============================================================================
# Integrations
# ============================================================================
# Symmetric key used to encrypt provider credentials at rest (AES-256-GCM).
# Generate a strong value in production, e.g. `openssl rand -base64 48`.
INTEGRATIONS_ENCRYPTION_KEY="replace-with-a-long-random-secret"
# Background workers (health monitor, calendar sync, webhook dispatcher).
INTEGRATIONS_BACKGROUND_JOBS=true
INTEGRATIONS_HEALTH_INTERVAL_MS=300000
INTEGRATIONS_SYNC_INTERVAL_MS=600000
INTEGRATIONS_WEBHOOK_INTERVAL_MS=15000

# --- Provider OAuth clients (calendar / video / CRM) ---
# Shared Google app powers Google Calendar + Google Meet.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Shared Microsoft app powers Outlook calendar + Teams meetings.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Note: API-key providers (Stripe, Razorpay, PayPal, Resend, Mailgun, SMTP,
# Twilio, MessageBird, Pipedrive, Slack, Discord, Zapier, Make, n8n, Apple
# Calendar) are configured per-organization through the Integrations UI, not
# via env vars.

# --- Observability ---
LOG_LEVEL=debug
