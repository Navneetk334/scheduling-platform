// ============================================================================
// INVINCIBLE PROS — Scheduling Platform data model
// PostgreSQL + Prisma. Multi-tenant (organization-scoped) with Better Auth
// compatible identity tables.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EventTypeKind {
  ONE_ON_ONE
  GROUP
  ROUND_ROBIN
  COLLECTIVE
}

enum LocationType {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  IN_PERSON
  PHONE
  CUSTOM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum AttendeeRole {
  HOST
  INVITEE
  GUEST
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

// ---------------------------------------------------------------------------
// Identity (Better Auth compatible)
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  timeZone      String   @default("UTC")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions            Session[]
  accounts            Account[]
  memberships         Membership[]
  schedules           Schedule[]
  eventTypes          EventType[]
  calendarConnections CalendarConnection[]
  sentInvitations     Invitation[]         @relation("InvitedBy")

  @@map("users")
}

model Session {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  timeZone  String    @default("UTC")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships            Membership[]
  invitations            Invitation[]
  schedules              Schedule[]
  eventTypes             EventType[]
  bookings               Booking[]
  integrationConnections IntegrationConnection[]
  integrationLogs        IntegrationLog[]
  webhookEndpoints       WebhookEndpoint[]

  @@map("organizations")
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           OrganizationRole @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([organizationId, email])
  @@index([email])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Availability
// ---------------------------------------------------------------------------

model Schedule {
  id             String   @id @default(cuid())
  organizationId String
  ownerId        String
  name           String
  timeZone       String   @default("UTC")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rules        AvailabilityRule[]
  overrides    DateOverride[]
  eventTypes   EventType[]

  @@index([organizationId])
  @@index([ownerId])
  @@map("schedules")
}

model AvailabilityRule {
  id          String @id @default(cuid())
  scheduleId  String
  weekday     Int // 0=Sunday .. 6=Saturday
  startMinute Int // minutes since midnight (schedule timezone)
  endMinute   Int

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("availability_rules")
}

model DateOverride {
  id         String @id @default(cuid())
  scheduleId String
  date       String // YYYY-MM-DD (schedule timezone)

  schedule  Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  intervals OverrideInterval[]

  @@unique([scheduleId, date])
  @@map("date_overrides")
}

model OverrideInterval {
  id          String @id @default(cuid())
  overrideId  String
  startMinute Int
  endMinute   Int

  override DateOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
  @@map("override_intervals")
}

// ---------------------------------------------------------------------------
// Event types
// ---------------------------------------------------------------------------

model EventType {
  id                   String        @id @default(cuid())
  organizationId       String
  ownerId              String
  scheduleId           String
  kind                 EventTypeKind @default(ONE_ON_ONE)
  title                String
  slug                 String
  description          String?
  durationMinutes      Int
  bufferBeforeMinutes  Int           @default(0)
  bufferAfterMinutes   Int           @default(0)
  minimumNoticeMinutes Int           @default(60)
  bookingWindowDays    Int           @default(60)
  slotIntervalMinutes  Int           @default(15)
  seatsPerSlot         Int           @default(1)
  isActive             Boolean       @default(true)
  color                String        @default("#4F46E5")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  schedule     Schedule            @relation(fields: [scheduleId], references: [id])
  locations    EventTypeLocation[]
  bookings     Booking[]

  @@unique([organizationId, slug])
  @@index([ownerId])
  @@index([scheduleId])
  @@map("event_types")
}

model EventTypeLocation {
  id          String       @id @default(cuid())
  eventTypeId String
  type        LocationType
  value       String?

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([eventTypeId])
  @@map("event_type_locations")
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id                String        @id @default(cuid())
  organizationId    String
  eventTypeId       String
  status            BookingStatus @default(CONFIRMED)
  startTime         DateTime
  endTime           DateTime
  timeZone          String
  location          Json?
  meetingUrl        String?
  notes             String?
  cancelReason      String?
  reference         String        @unique
  idempotencyKey    String?       @unique
  rescheduledFromId String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType       EventType    @relation(fields: [eventTypeId], references: [id])
  attendees       Attendee[]
  rescheduledFrom Booking?     @relation("Reschedule", fields: [rescheduledFromId], references: [id])
  rescheduledTo   Booking?     @relation("Reschedule")

  @@index([organizationId, startTime])
  @@index([eventTypeId, startTime, status])
  @@map("bookings")
}

model Attendee {
  id        String       @id @default(cuid())
  bookingId String
  role      AttendeeRole @default(INVITEE)
  name      String
  email     String
  timeZone  String       @default("UTC")
  userId    String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([email])
  @@map("attendees")
}

// ---------------------------------------------------------------------------
// Calendar integrations
// ---------------------------------------------------------------------------

model CalendarConnection {
  id           String           @id @default(cuid())
  userId       String
  provider     CalendarProvider
  email        String
  externalId   String
  isPrimary    Boolean          @default(false)
  syncEnabled  Boolean          @default(true)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, externalId])
  @@index([userId])
  @@map("calendar_connections")
}

// ---------------------------------------------------------------------------
// Integrations (calendar, video, payment, email, SMS, CRM, automation, chat)
//
// The provider catalog itself is code-driven (see @invincible/integrations).
// These tables persist per-organization *connections*, an append-only audit
// log, and outbound webhook subscriptions + their delivery attempts.
// ---------------------------------------------------------------------------

enum IntegrationCategory {
  CALENDAR
  VIDEO
  PAYMENT
  EMAIL
  SMS
  CRM
  AUTOMATION
  MESSAGING
}

/**
 * How a connection authenticates against the third-party provider.
 */
enum IntegrationAuthType {
  OAUTH2
  API_KEY
  BASIC
  SMTP
  WEBHOOK
  NONE
}

enum IntegrationConnectionStatus {
  PENDING
  ACTIVE
  DISABLED
  EXPIRED
  ERROR
}

/**
 * Rolled-up health of a connection, refreshed by the health monitor.
 */
enum IntegrationHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNHEALTHY
}

enum IntegrationLogDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum IntegrationLogStatus {
  SUCCESS
  FAILURE
  RETRYING
  SKIPPED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  RETRYING
  FAILED
  DEAD
}

/**
 * A single configured provider connection for an organization. Credentials are
 * stored encrypted (AES-256-GCM) in `encryptedCredentials`; never in plaintext.
 */
model IntegrationConnection {
  id                   String                      @id @default(cuid())
  organizationId       String
  provider             String // stable provider id, e.g. "google_calendar"
  category             IntegrationCategory
  authType             IntegrationAuthType
  displayName          String
  status               IntegrationConnectionStatus @default(PENDING)
  healthStatus         IntegrationHealthStatus     @default(UNKNOWN)
  // Encrypted JSON credential blob (tokens / api keys / smtp password).
  encryptedCredentials String?
  // Non-secret, provider-specific configuration (region, from-address, etc.).
  config               Json?
  scopes               String[]                    @default([])
  externalAccountId    String?
  externalAccountEmail String?
  // Opaque cursor for incremental background sync (e.g. calendar syncToken).
  syncCursor           String?
  tokenExpiresAt       DateTime?
  lastError            String?
  lastHealthCheckAt    DateTime?
  lastSyncedAt         DateTime?
  createdById          String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs         IntegrationLog[]

  @@unique([organizationId, provider, externalAccountId])
  @@index([organizationId, category])
  @@index([status])
  @@index([healthStatus])
  @@map("integration_connections")
}

/**
 * Append-only audit trail of every integration action (outbound API calls,
 * inbound webhooks, internal sync ticks). Powers the "Integration Logs" view.
 */
model IntegrationLog {
  id              String                  @id @default(cuid())
  organizationId  String
  connectionId    String?
  provider        String
  category        IntegrationCategory
  direction       IntegrationLogDirection
  action          String
  status          IntegrationLogStatus
  httpStatus      Int?
  durationMs      Int?
  attempt         Int                     @default(1)
  requestSummary  Json?
  responseSummary Json?
  error           String?
  createdAt       DateTime                @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([connectionId, createdAt])
  @@index([provider, status])
  @@map("integration_logs")
}

/**
 * Outbound webhook subscription. When platform events fire (booking.created,
 * booking.cancelled, ...) a signed delivery is enqueued for each active,
 * matching endpoint.
 */
model WebhookEndpoint {
  id              String   @id @default(cuid())
  organizationId  String
  url             String
  description     String?
  // HMAC signing secret (encrypted at rest).
  encryptedSecret String
  events          String[] @default([])
  isActive        Boolean  @default(true)
  headers         Json?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

/**
 * A single delivery attempt lifecycle for an outbound webhook.
 */
model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  organizationId String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempt        Int                   @default(0)
  maxAttempts    Int                   @default(6)
  responseStatus Int?
  responseBody   String?
  error          String?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([endpointId, createdAt])
  @@index([organizationId, createdAt])
  @@map("webhook_deliveries")
}
