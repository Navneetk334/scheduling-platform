// ============================================================================
// INVINCIBLE PROS — Scheduling Platform data model
// ----------------------------------------------------------------------------
// A fully-normalized, multi-tenant PostgreSQL schema (Prisma).
//
// Multi-tenancy: every tenant-scoped table carries `organizationId` (row-level
// tenancy in a shared database). Global tables (User, Plan, Permission,
// FeatureFlag) are intentionally NOT org-scoped.
//
// Money is stored as integer minor units (e.g. cents) + an ISO currency code.
// Identity tables (User/Session/Account/Verification) are Better Auth compatible.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum MeetingTypeKind {
  ONE_ON_ONE
  GROUP
  ROUND_ROBIN
  COLLECTIVE
}

enum HostAssignmentStrategy {
  ROUND_ROBIN_FAIR
  ROUND_ROBIN_WEIGHTED
  PRIORITY
  ALL_REQUIRED // collective
}

enum MeetingHostRole {
  ORGANIZER
  CO_HOST
  MEMBER
}

enum LocationKind {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  IN_PERSON
  PHONE
  CUSTOM
  ROOM
}

enum MeetingRoomKind {
  PHYSICAL
  VIRTUAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum GuestRole {
  INVITEE
  GUEST
}

enum WaitlistStatus {
  WAITING
  INVITED
  CONVERTED
  EXPIRED
  CANCELLED
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_SELECT
  MULTI_SELECT
  CHECKBOX
  NUMBER
  EMAIL
  PHONE
  DATE
  FILE
}

enum BillingInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  RAZORPAY
  MANUAL
}

enum ReferralStatus {
  PENDING
  CONVERTED
  REWARDED
  EXPIRED
}

enum UsageMetric {
  BOOKINGS
  STORAGE_GB
  API_REQUESTS
}

enum CouponType {
  PERCENT
  FIXED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  WEBHOOK
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum IntegrationType {
  ZAPIER
  SLACK
  DISCORD
  HUBSPOT
  SALESFORCE
  PIPEDRIVE
  ZOOM
  GOOGLE
  MICROSOFT
  WEBHOOK
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DomainStatus {
  PENDING
  VERIFYING
  VERIFIED
  ACTIVE
  FAILED
}

enum SslStatus {
  NONE
  PENDING
  ISSUED
  FAILED
}

/// How a domain maps to the platform: a *.platform subdomain or a fully custom hostname.
enum DomainKind {
  SUBDOMAIN
  CUSTOM
}

/// Default interface theme a brand renders with.
enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

/// Category of a stored brand asset.
enum BrandAssetType {
  LOGO
  LOGO_DARK
  FAVICON
  OG_IMAGE
  FONT
  IMAGE
}

/// The transactional message a template renders. Shared by email + SMS channels.
enum TemplateType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  BOOKING_RESCHEDULED
  BOOKING_CANCELLED
  BOOKING_FOLLOW_UP
  WAITLIST_CONFIRMATION
  PAYMENT_RECEIPT
  INVOICE_ISSUED
  TEAM_INVITE
  WELCOME
  PASSWORD_RESET
  CUSTOM
}

/// Legal document variants an organization can override per brand.
enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  COOKIE_POLICY
}

enum AuditActorType {
  USER
  SYSTEM
  API_KEY
}

// ===========================================================================
// Identity (global, Better Auth compatible)
// ===========================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  phone         String?
  timeZone      String   @default("UTC")
  locale        String   @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth
  sessions Session[]
  accounts Account[]

  // Tenancy
  memberships     Membership[]
  teamMemberships TeamMembership[]
  sentInvitations Invitation[]     @relation("InvitedBy")

  // Scheduling
  availabilities      Availability[]
  ownedMeetingTypes   MeetingType[]        @relation("MeetingTypeOwner")
  meetingTypeHosts    MeetingTypeHost[]
  assignedBookings    Booking[]            @relation("BookingAssignedHost")
  bookingHosts        BookingHost[]
  calendarConnections CalendarConnection[]

  // Platform
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  couponRedemptions CouponRedemption[]
  guestProfiles     Guest[]

  @@map("users")
}

model Session {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// OAuth + credential accounts (Better Auth). Covers social OAuth logins.
model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ===========================================================================
// Tenancy, Teams & RBAC
// ===========================================================================

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  timeZone  String    @default("UTC")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Tenancy graph
  memberships Membership[]
  teams       Team[]
  roles       Role[]
  invitations Invitation[]

  // Scheduling
  availabilities      Availability[]
  meetingTypes        MeetingType[]
  bookings            Booking[]
  locations           Location[]
  meetingRooms        MeetingRoom[]
  forms               Form[]
  waitlistItems       WaitlistEntry[]
  calendarConnections CalendarConnection[]

  // Platform
  integrations    Integration[]
  apiKeys         ApiKey[]
  webhooks        Webhook[]
  notificationLog NotificationLog[]
  auditLogs       AuditLog[]
  analyticsEvents AnalyticsEvent[]
  featureFlags    OrganizationFeatureFlag[]

  // Billing
  subscription      Subscription?
  invoices          Invoice[]
  payments          Payment[]
  coupons           Coupon[]
  couponRedemptions CouponRedemption[]
  paymentMethods    PaymentMethod[]
  usageRecords      UsageRecord[]
  referralsMade     Referral[]         @relation("Referrer")
  referralsReceived Referral[]         @relation("Referred")

  // White label & distribution
  brands           Brand[]
  brandAssets      BrandAsset[]
  messageTemplates MessageTemplate[]
  legalDocuments   LegalDocument[]
  domains          Domain[]

  @@index([deletedAt])
  @@map("organizations")
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  parentTeamId   String?
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentTeam   Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams   Team[]           @relation("TeamHierarchy")
  members      TeamMembership[]
  meetingTypes MeetingType[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentTeamId])
  @@map("teams")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  key            String // e.g. "owner", "admin", "member", or custom
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  memberships  Membership[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("roles")
}

/// Global catalog of permission keys (e.g. "booking.read", "member.invite").
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  category    String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String           @id @default(cuid())
  roleId       String
  permissionId String
  effect       PermissionEffect @default(ALLOW)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("memberships")
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  isLead    Boolean  @default(false)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  roleId         String?
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([organizationId, email])
  @@index([email])
  @@map("invitations")
}

// ===========================================================================
// Availability & Working Hours
// ===========================================================================

model Availability {
  id             String   @id @default(cuid())
  organizationId String
  ownerId        String
  name           String
  timeZone       String   @default("UTC")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workingHours WorkingHours[]
  overrides    AvailabilityOverride[]
  meetingTypes MeetingType[]

  @@index([organizationId])
  @@index([ownerId])
  @@map("availabilities")
}

/// Weekly recurring bookable windows for an availability profile.
model WorkingHours {
  id             String @id @default(cuid())
  availabilityId String
  weekday        Int // 0=Sunday .. 6=Saturday
  startMinute    Int // minutes since midnight (profile timezone)
  endMinute      Int

  availability Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("working_hours")
}

/// Date-specific override; empty intervals => that date is unavailable.
model AvailabilityOverride {
  id             String  @id @default(cuid())
  availabilityId String
  date           String // YYYY-MM-DD (profile timezone)
  isUnavailable  Boolean @default(false)

  availability Availability                   @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  intervals    AvailabilityOverrideInterval[]

  @@unique([availabilityId, date])
  @@map("availability_overrides")
}

model AvailabilityOverrideInterval {
  id          String @id @default(cuid())
  overrideId  String
  startMinute Int
  endMinute   Int

  override AvailabilityOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
  @@map("availability_override_intervals")
}

// ===========================================================================
// Locations & Meeting Rooms
// ===========================================================================

model Location {
  id             String       @id @default(cuid())
  organizationId String
  kind           LocationKind
  label          String
  value          String? // URL / address / phone depending on kind
  meetingRoomId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meetingRoom      MeetingRoom?          @relation(fields: [meetingRoomId], references: [id])
  meetingTypeLinks MeetingTypeLocation[]
  bookings         Booking[]

  @@index([organizationId])
  @@map("locations")
}

model MeetingRoom {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  kind           MeetingRoomKind @default(PHYSICAL)
  capacity       Int             @default(1)
  timeZone       String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations    Location[]
  bookings     Booking[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("meeting_rooms")
}

// ===========================================================================
// Meeting Types (event types)
// ===========================================================================

model MeetingType {
  id                   String                 @id @default(cuid())
  organizationId       String
  ownerId              String
  teamId               String?
  availabilityId       String
  formId               String?
  kind                 MeetingTypeKind        @default(ONE_ON_ONE)
  assignmentStrategy   HostAssignmentStrategy @default(ROUND_ROBIN_FAIR)
  title                String
  slug                 String
  description          String?
  durationMinutes      Int
  bufferBeforeMinutes  Int                    @default(0)
  bufferAfterMinutes   Int                    @default(0)
  minimumNoticeMinutes Int                    @default(60)
  bookingWindowDays    Int                    @default(60)
  slotIntervalMinutes  Int                    @default(15)
  seatsPerSlot         Int                    @default(1)
  maxPerDay            Int?
  maxPerWeek           Int?
  isActive             Boolean                @default(true)
  isPrivate            Boolean                @default(false)
  color                String                 @default("#4F46E5")
  priceAmount          Int? // minor units; null = free
  priceCurrency        String?
  recurrenceRule       String? // RRULE for recurring meetings
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner         User                  @relation("MeetingTypeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  team          Team?                 @relation(fields: [teamId], references: [id])
  availability  Availability          @relation(fields: [availabilityId], references: [id])
  form          Form?                 @relation(fields: [formId], references: [id])
  hosts         MeetingTypeHost[]
  locationLinks MeetingTypeLocation[]
  bookings      Booking[]
  waitlist      WaitlistEntry[]

  @@unique([organizationId, slug])
  @@index([ownerId])
  @@index([teamId])
  @@index([availabilityId])
  @@map("meeting_types")
}

/// Host pool for round-robin / collective meeting types.
model MeetingTypeHost {
  id            String          @id @default(cuid())
  meetingTypeId String
  userId        String
  role          MeetingHostRole @default(MEMBER)
  priority      Int             @default(0)
  weight        Int             @default(1)

  meetingType MeetingType @relation(fields: [meetingTypeId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingTypeId, userId])
  @@index([userId])
  @@map("meeting_type_hosts")
}

model MeetingTypeLocation {
  id            String @id @default(cuid())
  meetingTypeId String
  locationId    String
  position      Int    @default(0)

  meetingType MeetingType @relation(fields: [meetingTypeId], references: [id], onDelete: Cascade)
  location    Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([meetingTypeId, locationId])
  @@index([locationId])
  @@map("meeting_type_locations")
}

// ===========================================================================
// Forms, Questions & Responses
// ===========================================================================

model Form {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questions    Question[]
  meetingTypes MeetingType[]
  responses    FormResponse[]

  @@index([organizationId])
  @@map("forms")
}

model Question {
  id       String       @id @default(cuid())
  formId   String
  type     QuestionType
  label    String
  key      String
  helpText String?
  required Boolean      @default(false)
  position Int          @default(0)
  options  Json? // for select/multi-select
  config   Json?

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([formId, key])
  @@index([formId])
  @@map("questions")
}

model FormResponse {
  id             String   @id @default(cuid())
  organizationId String
  formId         String
  bookingId      String?  @unique
  createdAt      DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([formId])
  @@map("form_responses")
}

model Answer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  value      Json // string | string[] | number | boolean | file ref

  response FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([questionId])
  @@map("answers")
}

// ===========================================================================
// Bookings, Guests & Waitlists
// ===========================================================================

model Booking {
  id                String        @id @default(cuid())
  organizationId    String
  meetingTypeId     String
  assignedHostId    String?
  locationId        String?
  meetingRoomId     String?
  status            BookingStatus @default(CONFIRMED)
  startTime         DateTime
  endTime           DateTime
  timeZone          String
  meetingUrl        String?
  notes             String?
  cancelReason      String?
  cancelledAt       DateTime?
  priceAmount       Int?
  priceCurrency     String?
  reference         String        @unique
  idempotencyKey    String?       @unique
  rescheduledFromId String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meetingType      MeetingType       @relation(fields: [meetingTypeId], references: [id])
  assignedHost     User?             @relation("BookingAssignedHost", fields: [assignedHostId], references: [id])
  location         Location?         @relation(fields: [locationId], references: [id])
  meetingRoom      MeetingRoom?      @relation(fields: [meetingRoomId], references: [id])
  guests           Guest[]
  hosts            BookingHost[]
  formResponse     FormResponse?
  payment          Payment?
  couponRedemption CouponRedemption?
  rescheduledFrom  Booking?          @relation("Reschedule", fields: [rescheduledFromId], references: [id])
  rescheduledTo    Booking?          @relation("Reschedule")

  @@index([organizationId, startTime])
  @@index([meetingTypeId, startTime, status])
  @@index([assignedHostId, startTime])
  @@map("bookings")
}

model Guest {
  id        String    @id @default(cuid())
  bookingId String
  userId    String?
  role      GuestRole @default(INVITEE)
  name      String
  email     String
  phone     String?
  timeZone  String    @default("UTC")
  isPrimary Boolean   @default(false)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@index([email])
  @@map("guests")
}

/// Internal hosts attending a booking (collective / round-robin record).
model BookingHost {
  id        String          @id @default(cuid())
  bookingId String
  userId    String
  role      MeetingHostRole @default(ORGANIZER)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([bookingId, userId])
  @@index([userId])
  @@map("booking_hosts")
}

model WaitlistEntry {
  id             String         @id @default(cuid())
  organizationId String
  meetingTypeId  String
  name           String
  email          String
  phone          String?
  timeZone       String         @default("UTC")
  requestedStart DateTime?
  status         WaitlistStatus @default(WAITING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meetingType  MeetingType  @relation(fields: [meetingTypeId], references: [id], onDelete: Cascade)

  @@index([meetingTypeId, status])
  @@index([email])
  @@map("waitlist_entries")
}

// ===========================================================================
// Calendars & Connections
// ===========================================================================

/// A user's OAuth connection to an external calendar provider, scoped to an org.
model CalendarConnection {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  provider       CalendarProvider
  email          String
  externalId     String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  syncEnabled    Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendars    Calendar[]

  @@unique([userId, provider, externalId])
  @@index([userId])
  @@index([organizationId])
  @@map("calendar_connections")
}

/// Individual calendars within a connection (e.g. "Work", "Personal").
model Calendar {
  id                String  @id @default(cuid())
  connectionId      String
  externalId        String
  name              String
  color             String?
  isPrimary         Boolean @default(false)
  checkForConflicts Boolean @default(true)
  writeBookings     Boolean @default(false)

  connection CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalId])
  @@index([connectionId])
  @@map("calendars")
}

// ===========================================================================
// Integrations, API Keys & Webhooks
// ===========================================================================

model Integration {
  id                String            @id @default(cuid())
  organizationId    String
  type              IntegrationType
  status            IntegrationStatus @default(CONNECTED)
  externalAccountId String?
  config            Json?
  credentials       Json? // encrypted at the application layer
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, externalAccountId])
  @@index([organizationId])
  @@map("integrations")
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  prefix         String
  hashedKey      String    @unique
  scopes         String[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@map("api_keys")
}

model Webhook {
  id             String        @id @default(cuid())
  organizationId String
  url            String
  secret         String
  events         String[]
  status         WebhookStatus @default(ACTIVE)
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("webhooks")
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  webhookId      String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  responseStatus Int?
  attempts       Int                   @default(0)
  error          String?
  lastAttemptAt  DateTime?
  createdAt      DateTime              @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@map("webhook_deliveries")
}

// ===========================================================================
// Notifications & Audit
// ===========================================================================

model NotificationLog {
  id                String              @id @default(cuid())
  organizationId    String
  channel           NotificationChannel
  template          String
  recipient         String
  subject           String?
  bookingId         String?
  status            NotificationStatus  @default(QUEUED)
  providerMessageId String?
  error             String?
  scheduledFor      DateTime?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([bookingId])
  @@map("notification_logs")
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String
  actorType      AuditActorType @default(USER)
  actorId        String?
  action         String // e.g. "booking.cancelled"
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  userId         String?
  bookingId      String?
  meetingTypeId  String?
  properties     Json?
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, name, occurredAt])
  @@map("analytics_events")
}

// ===========================================================================
// Billing: Plans, Subscriptions, Invoices, Payments, Coupons
// ===========================================================================

/// Global catalog of SaaS plans.
model Plan {
  id            String          @id @default(cuid())
  key           String          @unique
  name          String
  description   String?
  priceAmount   Int             @default(0)
  currency      String          @default("usd")
  interval      BillingInterval @default(MONTH)
  stripePriceId String?
  features      Json?
  isPublic      Boolean         @default(true)
  sortOrder     Int             @default(0)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  planId               String
  status               SubscriptionStatus @default(TRIALING)
  interval             BillingInterval    @default(MONTH)
  seats                Int                @default(1)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  gracePeriodEndsAt    DateTime?
  lastPaymentFailedAt  DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscriptions")
}

model Invoice {
  id              String        @id @default(cuid())
  organizationId  String
  number          String        @unique
  status          InvoiceStatus @default(DRAFT)
  currency        String        @default("usd")
  subtotal        Int           @default(0)
  discountTotal   Int           @default(0)
  taxTotal        Int           @default(0)
  total           Int           @default(0)
  amountPaid      Int           @default(0)
  amountDue       Int           @default(0)
  taxType         String? // GST | VAT | SALES | NONE
  taxRatePct      Int? // whole-number percentage, e.g. 18
  taxCountry      String?
  dueDate         DateTime?
  issuedAt        DateTime?
  paidAt          DateTime?
  stripeInvoiceId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems    InvoiceLineItem[]
  payments     Payment[]

  @@index([organizationId, status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int    @default(1)
  unitAmount  Int
  amount      Int
  metadata    Json?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id                String          @id @default(cuid())
  organizationId    String
  bookingId         String?         @unique
  invoiceId         String?
  amount            Int
  currency          String          @default("usd")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider @default(STRIPE)
  providerPaymentId String?
  method            String?
  refundedAmount    Int             @default(0)
  failureReason     String?
  retryCount        Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId, status])
  @@index([invoiceId])
  @@map("payments")
}

model Coupon {
  id             String     @id @default(cuid())
  organizationId String
  code           String
  type           CouponType @default(PERCENT)
  amountOff      Int // percent (0-100) or fixed minor units depending on type
  currency       String?
  maxRedemptions Int?
  timesRedeemed  Int        @default(0)
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  redemptions  CouponRedemption[]

  @@unique([organizationId, code])
  @@map("coupons")
}

model CouponRedemption {
  id               String   @id @default(cuid())
  organizationId   String
  couponId         String
  bookingId        String?  @unique
  userId           String?
  amountDiscounted Int
  redeemedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coupon       Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@map("coupon_redemptions")
}

// ===========================================================================
// Platform config: Feature Flags, White Label, Domains
// ===========================================================================

model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  description    String?
  defaultEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())

  organizations OrganizationFeatureFlag[]

  @@map("feature_flags")
}

model OrganizationFeatureFlag {
  id             String  @id @default(cuid())
  organizationId String
  flagId         String
  enabled        Boolean

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flag         FeatureFlag  @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@unique([organizationId, flagId])
  @@map("organization_feature_flags")
}

// ===========================================================================
// White label
// ---------------------------------------------------------------------------
// An organization may own MANY brands (multi-brand). Each brand fully
// customizes booking pages, emails, login, legal docs, colors, fonts, and
// (optionally) its own custom domain. Exactly one brand per org is `isDefault`.
// ===========================================================================

/// A fully customizable brand identity owned by an organization.
model Brand {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  /// URL-safe handle, unique within the organization; used in branded URLs.
  slug           String
  isDefault      Boolean @default(false)
  isActive       Boolean @default(true)

  // Visual identity
  logoUrl     String?
  logoDarkUrl String?
  faviconUrl  String?
  ogImageUrl  String?

  // Color tokens (hex). Per-mode token sets live in BrandTheme.
  primaryColor    String @default("#4F46E5")
  accentColor     String @default("#06B6D4")
  backgroundColor String @default("#FFFFFF")
  foregroundColor String @default("#0F172A")

  // Typography
  headingFont   String  @default("Inter")
  bodyFont      String  @default("Inter")
  customFontUrl String?

  // Presentation
  defaultThemeMode ThemeMode @default(SYSTEM)
  customCss        String?
  footerHtml       String?
  /// Hide "Powered by INVINCIBLE PROS" across booking pages, emails, etc.
  removeBranding   Boolean   @default(false)

  // Custom login page
  loginHeadline    String?
  loginSubheadline String?
  loginImageUrl    String?

  // Messaging identity
  emailFromName    String?
  emailFromAddress String?
  emailReplyTo     String?
  supportEmail     String?
  smsSenderId      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  themes         BrandTheme[]
  assets         BrandAsset[]
  templates      MessageTemplate[]
  legalDocuments LegalDocument[]
  domains        Domain[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("brands")
}

/// A per-mode set of design tokens (light/dark) for a brand.
model BrandTheme {
  id        String    @id @default(cuid())
  brandId   String
  mode      ThemeMode
  /// Design tokens: background, foreground, primary, accent, muted, border, radius…
  tokens    Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, mode])
  @@index([brandId])
  @@map("brand_themes")
}

/// Reusable brand asset (logo, favicon, font, image) stored in the asset library.
model BrandAsset {
  id             String         @id @default(cuid())
  organizationId String
  brandId        String?
  type           BrandAssetType
  name           String
  url            String
  mimeType       String?
  sizeBytes      Int?
  width          Int?
  height         Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([brandId])
  @@map("brand_assets")
}

/// A branded, overridable email/SMS template for a transactional message.
model MessageTemplate {
  id             String              @id @default(cuid())
  organizationId String
  /// Null = organization-wide default; set = brand-specific override.
  brandId        String?
  channel        NotificationChannel
  type           TemplateType
  name           String
  /// Email only; SMS ignores subject.
  subject        String?
  bodyHtml       String?
  bodyText       String
  /// Declared template variables, e.g. { "guestName": "Invitee full name" }.
  variables      Json?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([organizationId, brandId, channel, type])
  @@index([organizationId])
  @@index([brandId])
  @@map("message_templates")
}

/// Custom legal document (privacy/terms/cookie) overriding platform defaults.
model LegalDocument {
  id             String            @id @default(cuid())
  organizationId String
  brandId        String?
  type           LegalDocumentType
  title          String
  content        String
  version        Int               @default(1)
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([organizationId, brandId, type])
  @@index([organizationId])
  @@index([brandId])
  @@map("legal_documents")
}

/// A custom domain or platform subdomain, with DNS + SSL provisioning state.
model Domain {
  id             String     @id @default(cuid())
  organizationId String
  brandId        String?
  kind           DomainKind @default(CUSTOM)
  /// Full hostname, e.g. "book.acme.com" or "acme.invinciblepros.app".
  hostname       String     @unique
  /// Subdomain label when kind = SUBDOMAIN (e.g. "acme").
  subdomain      String?
  isPrimary      Boolean    @default(false)

  // Verification
  status            DomainStatus @default(PENDING)
  verificationToken String?
  /// Expected DNS records the customer must add (TXT/CNAME) for verification.
  dnsRecords        Json?
  verifiedAt        DateTime?
  dnsVerifiedAt     DateTime?
  lastCheckedAt     DateTime?
  failureReason     String?

  // TLS
  sslStatus    SslStatus @default(NONE)
  sslIssuedAt  DateTime?
  sslExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([brandId])
  @@map("domains")
}

// ===========================================================================
// Billing extensions: payment methods, usage metering, referrals, campaigns
// ===========================================================================

model PaymentMethod {
  id             String          @id @default(cuid())
  organizationId String
  gateway        PaymentProvider @default(STRIPE)
  brand          String? // visa, mastercard, amex…
  last4          String?
  expMonth       Int?
  expYear        Int?
  isDefault      Boolean         @default(false)
  externalId     String? // gateway token / payment-method id
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("payment_methods")
}

/// Metered usage aggregated per billing period (drives usage-based charges).
model UsageRecord {
  id             String      @id @default(cuid())
  organizationId String
  metric         UsageMetric
  quantity       Int         @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metric, periodStart])
  @@index([organizationId, metric])
  @@map("usage_records")
}

model Referral {
  id                     String         @id @default(cuid())
  code                   String         @unique
  referrerOrganizationId String
  referredOrganizationId String?
  discountPercent        Int            @default(20)
  status                 ReferralStatus @default(PENDING)
  rewardedAt             DateTime?
  expiresAt              DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  referrer Organization  @relation("Referrer", fields: [referrerOrganizationId], references: [id], onDelete: Cascade)
  referred Organization? @relation("Referred", fields: [referredOrganizationId], references: [id])

  @@index([referrerOrganizationId])
  @@map("referrals")
}

/// Platform-wide discount campaigns (not tenant-scoped).
model DiscountCampaign {
  id             String     @id @default(cuid())
  name           String
  code           String     @unique
  type           CouponType @default(PERCENT)
  amountOff      Int
  currency       String?
  startsAt       DateTime?
  endsAt         DateTime?
  maxRedemptions Int?
  timesRedeemed  Int        @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("discount_campaigns")
}
