{
  "name": "invincible-pros-scheduling",
  "version": "0.1.0",
  "private": true,
  "description": "INVINCIBLE PROS — enterprise-grade scheduling SaaS platform",
  "author": "INVINCIBLE PROS",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @invincible/database db:generate",
    "db:migrate": "pnpm --filter @invincible/database db:migrate",
    "db:push": "pnpm --filter @invincible/database db:push",
    "db:seed": "pnpm --filter @invincible/database db:seed",
    "db:studio": "pnpm --filter @invincible/database db:studio",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["prettier --write"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@prisma/client", "prisma", "@prisma/engines"]
  }
}
