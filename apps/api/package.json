{
  "name": "@invincible/api",
  "version": "0.1.0",
  "private": true,
  "description": "INVINCIBLE PROS scheduling platform — NestJS API",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "sdk:generate": "pnpm openapi:export && npx --yes @hey-api/openapi-ts@latest -i openapi.json -o ../../packages/sdk/src/generated"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@invincible/database": "workspace:*",
    "@invincible/types": "workspace:*",
    "@invincible/utils": "workspace:*",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "better-auth": "^1.1.14",
    "bullmq": "^5.34.0",
    "graphql": "^16.10.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.3.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "supertest": "^7.0.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
